# =============================================================================
# e-motion Warisan Edition — Environment Variables
# Copy this file to .env.local and fill in the values before running locally.
# In production (Vercel), add these in Project Settings → Environment Variables.
# =============================================================================

# --- Supabase (required) -----------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — only needed if RLS blocks anon reads on
# rsvps / ucapan tables. Keep secret: NEVER prefix with NEXT_PUBLIC_.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Admin Dashboard (required) ----------------------------------------------
# Single shared password for /admin access
ADMIN_PASSWORD=change-me-to-something-strong

# 32+ random bytes for HMAC session signing.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=change-me-to-at-least-32-random-bytes

# --- Business Contact (used in footer and pricing CTAs) ----------------------
# Malaysian format without +, e.g. 601139697861
NEXT_PUBLIC_CONTACT_WA=601139697861

NEXT_PUBLIC_CONTACT_EMAIL=hello@e-motion.my

# Production base URL — no trailing slash. Used for OG image URLs.
NEXT_PUBLIC_BASE_URL=https://e-motion.my
